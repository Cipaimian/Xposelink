# Xposelink — single environment file for both local dev and Docker deploy.
#
# Setup:
#   cp .env.example .env
#   then fill in the values below.
#
# This file is loaded by:
#   - backend/index.js (local dev: `npm run dev`)
#   - docker compose (auto-loads .env from project root)
# So both environments share the same secrets.

# ─── Docker host ports (only override if 80/443 are taken by another app) ───
# Default: Caddy binds host 80/443 directly and handles HTTPS.
# If a host-level reverse proxy already uses 80/443, set these to free ports
# and forward xposelink.site / api.xposelink.site from that proxy to here.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ─── Server ──────────────────────────────────────────────────────────────────
# Generate a strong random string: `openssl rand -hex 64`
JWT_SECRET=replace-with-a-long-random-string

# Production (default). For local dev change to:
#   PUBLIC_BASE_URL=http://localhost:3000
#   FRONTEND_URL=http://localhost:5173
PORT=3000
PUBLIC_BASE_URL=https://xposelink.site
FRONTEND_URL=https://xposelink.site

# Base URL the frontend calls for the API. Same-origin by default (the SPA and
# /api/* are both served from xposelink.site). Baked into the build at compile
# time, so a rebuild (`docker compose up -d --build`) is required after changing.
VITE_API_BASE_URL=https://xposelink.site

# ─── Admin account ───────────────────────────────────────────────────────────
# Seeded on first DB init. Change these BEFORE starting the server.
ADMIN_EMAIL=admin@xposelink.site
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── MySQL ───────────────────────────────────────────────────────────────────
# Docker (default): DB_HOST=mysql (matches the service name in docker-compose.yml)
# Local dev:        DB_HOST=localhost (XAMPP / standalone MySQL on your machine)
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASS=replace-with-a-strong-mysql-password
DB_NAME=xposelink

# ─── VirusTotal (optional) ───────────────────────────────────────────────────
# Free key at https://www.virustotal.com/gui/my-apikey
# Leave empty to use heuristic-only security checks.
VIRUSTOTAL_API_KEY=

# ─── PhishTank (optional) ────────────────────────────────────────────────────
# Free key at https://www.phishtank.com/api_register.php
# If empty, the server falls back to OpenPhish's free public feed.
PHISHTANK_API_KEY=

# ─── Midtrans payment gateway (optional) ─────────────────────────────────────
# Sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config
# Leave empty to use the mock payment flow (no real charges).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ─── SMTP / Email (optional) ─────────────────────────────────────────────────
# Used for email verification & password reset emails.
# If unset, emails are printed to the server console.
# Example providers: Brevo (smtp-relay.brevo.com), Gmail (smtp.gmail.com), SendGrid
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Xposelink <noreply@xposelink.id>
