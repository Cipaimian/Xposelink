{
  "manifest_version": 3,
  "name": "Xposelink Security",
  "version": "1.0.0",
  "description": "Preview links safely before visiting. Detect threats, shorten and unshorten URLs, powered by Xposelink.",
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "clipboardWrite",
    "cookies",
    "storage",
    "notifications",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/logo16.png",
      "48":  "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  },
  "icons": {
    "16":  "icons/logo16.png",
    "48":  "icons/logo48.png",
    "128": "icons/logo128.png"
  }
}
